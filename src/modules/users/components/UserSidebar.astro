---
const { currentPath } = Astro.props;

const isAdminContext = currentPath.startsWith("/admin/");
const isActive = (path: string) => currentPath === path;
---

<div class="space-y-1 h-full flex flex-col">
    <!-- Context Header -->
    <div class="px-3 mb-2">
        <h2
            class="text-xs font-semibold text-gray-500 uppercase tracking-wider"
        >
            {isAdminContext ? "Administração" : "Módulo Usuários"}
        </h2>
    </div>

    {
        isAdminContext ? (
            /* Admin Menu Items */
            <>
                <a
                    href="/admin/departments"
                    class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                        isActive("/admin/departments")
                            ? "bg-white text-brand border border-gray-200 shadow-sm"
                            : "text-text-secondary hover:bg-gray-100"
                    }`}
                >
                    Departamentos
                </a>
                <a
                    href="/admin/job-titles"
                    class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                        isActive("/admin/job-titles")
                            ? "bg-white text-brand border border-gray-200 shadow-sm"
                            : "text-text-secondary hover:bg-gray-100"
                    }`}
                >
                    Cargos
                </a>
                <a
                    href="/admin/sectors"
                    class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                        isActive("/admin/sectors")
                            ? "bg-white text-brand border border-gray-200 shadow-sm"
                            : "text-text-secondary hover:bg-gray-100"
                    }`}
                >
                    Setores
                </a>
                <a
                    href="#"
                    class="block px-3 py-2 text-sm font-medium text-text-secondary hover:bg-gray-100 rounded-md transition-colors opacity-60 cursor-not-allowed"
                    title="Em breve"
                >
                    Grupos & Permissões
                </a>
                <a
                    href="#"
                    class="block px-3 py-2 text-sm font-medium text-text-secondary hover:bg-gray-100 rounded-md transition-colors opacity-60 cursor-not-allowed"
                    title="Em breve"
                >
                    Log de Auditoria
                </a>
            </>
        ) : (
            /* User Menu Items */
            <a
                href="/users"
                class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                    isActive("/users")
                        ? "bg-white text-brand border border-gray-200 shadow-sm"
                        : "text-text-secondary hover:bg-gray-100"
                }`}
            >
                Colaboradores
            </a>
            <a
                href="/organogram"
                class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                    isActive("/organogram")
                        ? "bg-white text-brand border border-gray-200 shadow-sm"
                        : "text-text-secondary hover:bg-gray-100"
                }`}
            >
                Organograma
            </a>
            <a
                href="/users/movements"
                class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                    isActive("/users/movements")
                        ? "bg-white text-brand border border-gray-200 shadow-sm"
                        : "text-text-secondary hover:bg-gray-100"
                }`}
            >
                Movimentações
            </a>
        )
    }

    <!-- Footer Action -->
    <div class="mt-auto pt-4 border-t border-gray-200">
        {
            isAdminContext ? (
                <a
                    href="/users"
                    class="flex items-center px-3 py-2 text-sm font-medium text-text-secondary hover:text-brand hover:bg-gray-50 rounded-md transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="mr-3 h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"
                        />
                    </svg>
                    Voltar ao Módulo
                </a>
            ) : (
                <a
                    href="/admin/departments"
                    class="flex items-center px-3 py-2 text-sm font-medium text-text-secondary hover:text-brand hover:bg-gray-50 rounded-md transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="mr-3 h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                        />
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                        />
                    </svg>
                    Administrador
                </a>
            )
        }
    </div>
</div>
