---
import AppLayout from "../../layouts/AppLayout.astro";
import UserSidebar from "../../modules/users/components/UserSidebar.astro";
import Organogram from "../../modules/users/components/Organogram";
---

<AppLayout title="Organograma - Gerenciar">
    <UserSidebar slot="sidebar" currentPath={Astro.url.pathname} />

    <div class="h-full flex flex-col pt-6">
        <div
            class="flex-1 overflow-hidden bg-gray-50 rounded-xl border border-gray-200 relative"
        >
            <Organogram client:only="react" />
        </div>
    </div>
</AppLayout>
