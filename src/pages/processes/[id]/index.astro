---
import AppLayout from "../../../layouts/AppLayout.astro";
import { ProcessViewer } from "../../../modules/processes/components/viewer/ProcessViewer";
import { ProcessSidebar } from "../../../modules/processes/components/shared/ProcessSidebar";

const { id } = Astro.params;
---

<AppLayout title="Visualizar Processo" rawSidebar={true}>
    <ProcessSidebar client:load slot="sidebar" />
    <ProcessViewer client:only="react" processId={id} />
</AppLayout>
