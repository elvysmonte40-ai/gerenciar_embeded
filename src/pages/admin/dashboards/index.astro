---
import AppLayout from "../../../layouts/AppLayout.astro";
import AdminSidebar from "../../../components/AdminSidebar.astro";
import DashboardList from "../../../modules/admin/components/DashboardList";

// Server-side check could be added here similar to settings page
---

<AppLayout title="Gerenciar Dashboards">
    <AdminSidebar slot="sidebar" />

    <div class="px-4 py-6 sm:px-0">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">
                Gerenciar Dashboards
            </h1>
            <p class="mt-2 text-sm text-gray-600">
                Configure os dashboards do Power BI disponíveis para sua
                organização.
            </p>
        </div>

        <!-- Dashboard List Component -->
        <DashboardList client:load />
    </div>
</AppLayout>
