---
import AppLayout from "../../../layouts/AppLayout.astro";
import AdminSidebar from "../../../components/AdminSidebar.astro";
import { AuditDashboard } from "../../../modules/admin/components/AuditDashboard";
import { AuditLogsViewer } from "../../../modules/admin/components/AuditLogsViewer";
---

<AppLayout title="Auditoria do Sistema | MIS">
    <AdminSidebar slot="sidebar" />

    <div class="max-w-7xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">
                    Auditoria do Sistema
                </h1>
                <p class="mt-1 text-sm text-gray-500">
                    Monitore acessos, ativações e eventos de segurança.
                </p>
            </div>
        </div>

        <!-- Dashboard Metrics -->
        <AuditDashboard client:load />

        <!-- Audit Logs Table -->
        <AuditLogsViewer client:load />
    </div>
</AppLayout>
