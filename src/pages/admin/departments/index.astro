---
import AppLayout from "../../../layouts/AppLayout.astro";
import DepartmentList from "../../../modules/admin/departments/components/DepartmentList";
import UserSidebar from "../../../modules/users/components/UserSidebar.astro";
---

<AppLayout title="Gerenciar - Departamentos">
    <UserSidebar slot="sidebar" currentPath="/admin/departments" />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Departamentos</h1>
            <p class="mt-1 text-sm text-gray-500">
                Gerencie os departamentos e setores da sua organização.
            </p>
        </div>

        <DepartmentList client:load />
    </div>
</AppLayout>
