---
import AppLayout from "../../../layouts/AppLayout.astro";
import SectorList from "../../../modules/admin/sectors/components/SectorList";
import UserSidebar from "../../../modules/users/components/UserSidebar.astro";
---

<AppLayout title="Gerenciar - Setores">
    <UserSidebar slot="sidebar" currentPath="/admin/sectors" />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Setores</h1>
            <p class="mt-1 text-sm text-gray-500">
                Gerencie os setores e divisões da sua organização.
            </p>
        </div>

        <SectorList client:load />
    </div>
</AppLayout>
