---
import AppLayout from "../../../layouts/AppLayout.astro";
import JobTitleList from "../../../modules/admin/job-titles/components/JobTitleList";
import UserSidebar from "../../../modules/users/components/UserSidebar.astro";
---

<AppLayout title="Gerenciar - Cargos">
    <UserSidebar slot="sidebar" currentPath="/admin/job-titles" />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Cargos</h1>
            <p class="mt-1 text-sm text-gray-500">
                Gerencie os cargos e funções da sua organização.
            </p>
        </div>

        <JobTitleList client:load />
    </div>
</AppLayout>
