---
import AppLayout from "../../layouts/AppLayout.astro";
import { DashboardEmbed } from "../../components/DashboardEmbed";

// Server-side check: Ensure session exists (TODO: Integrate with Supabase Auth Middleware)
// const accessToken = ...
---

<AppLayout title="Dashboard de Vendas">
  <div slot="sidebar" class="space-y-1 flex flex-col h-full">
    <div class="flex-1 space-y-1">
      <a
        href="/dashboard"
        class="block px-3 py-2 text-sm font-medium text-brand bg-white border border-gray-200 rounded-md shadow-sm"
      >
        Visão Geral
      </a>
      <a
        href="#"
        class="block px-3 py-2 text-sm font-medium text-text-secondary hover:bg-gray-100 rounded-md"
      >
        Relatórios Financeiros
      </a>
      <a
        href="#"
        class="block px-3 py-2 text-sm font-medium text-text-secondary hover:bg-gray-100 rounded-md"
      >
        Metas Trimestrais
      </a>
    </div>

    <!-- Admin Link (Hidden by default) -->
    <a
      href="/admin/settings"
      id="admin-sidebar-link"
      class="hidden mt-auto px-3 py-2 text-sm font-medium text-text-secondary hover:text-brand border-t border-gray-200 pt-4"
    >
      <div class="flex items-center gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
          ></path>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        Administrador
      </div>
    </a>
  </div>

  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-semibold text-text-primary">Visão Geral</h1>
      <div class="flex gap-2">
        <button
          class="px-4 py-2 bg-white border border-gray-200 rounded-md text-sm font-medium text-text-secondary hover:bg-gray-50 shadow-sm"
        >
          Exportar PDF
        </button>
        <button
          class="px-4 py-2 bg-brand text-white rounded-md text-sm font-medium hover:bg-brand-dark shadow-sm"
        >
          Atualizar Dados
        </button>
      </div>
    </div>

    <!-- Power BI Embed Component -->
    <div
      class="w-full bg-white rounded-xl border border-gray-200 shadow-sm p-1 min-h-[600px]"
    >
      <DashboardEmbed client:only="react" />
    </div>
  </div>
</AppLayout>

<script>
  import { supabase } from "../../lib/supabase";

  async function checkAdmin() {
    try {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!session) return;

      const { data: profile } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", session.user.id)
        .single();

      if (profile && profile.role === "admin") {
        const adminLink = document.getElementById("admin-sidebar-link");
        if (adminLink) adminLink.classList.remove("hidden");
      }
    } catch (e) {
      console.error("Error checking admin role:", e);
    }
  }

  checkAdmin();
</script>
