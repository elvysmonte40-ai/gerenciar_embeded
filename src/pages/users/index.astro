---
import AppLayout from "../../layouts/AppLayout.astro";
import UserList from "../../modules/users/components/UserList";
---

<AppLayout title="Gerenciamento de Usuários">
    <div slot="sidebar" class="space-y-1">
        <div class="px-3 mb-2">
            <h2
                class="text-xs font-semibold text-gray-500 uppercase tracking-wider"
            >
                Módulo Usuários
            </h2>
        </div>
        <a
            href="/users"
            class="block px-3 py-2 text-sm font-medium text-brand bg-white border border-gray-200 rounded-md shadow-sm transition-colors"
        >
            Colaboradores
        </a>
        <a
            href="#"
            class="block px-3 py-2 text-sm font-medium text-text-secondary hover:bg-gray-100 rounded-md transition-colors opacity-60 cursor-not-allowed"
            title="Em breve"
        >
            Grupos & Permissões
        </a>
        <a
            href="#"
            class="block px-3 py-2 text-sm font-medium text-text-secondary hover:bg-gray-100 rounded-md transition-colors opacity-60 cursor-not-allowed"
            title="Em breve"
        >
            Log de Auditoria
        </a>
    </div>

    <div class="space-y-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-semibold text-text-primary">
                    Usuários
                </h1>
                <p class="text-sm text-text-secondary mt-1">
                    Gerencie o acesso e permissões da sua equipe.
                </p>
            </div>
        </div>

        <UserList client:only="react" />
    </div>
</AppLayout>
