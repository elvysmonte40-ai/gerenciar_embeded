---
import AppLayout from "../../layouts/AppLayout.astro";
import UserList from "../../modules/users/components/UserList";
import UserSidebar from "../../modules/users/components/UserSidebar.astro";
---

<AppLayout title="Gerenciamento de Usuários">
    <UserSidebar slot="sidebar" currentPath="/users" />

    <div class="space-y-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-semibold text-text-primary">
                    Usuários
                </h1>
                <p class="text-sm text-text-secondary mt-1">
                    Gerencie o acesso e permissões da sua equipe.
                </p>
            </div>
        </div>

        <UserList client:only="react" />
    </div>
</AppLayout>
