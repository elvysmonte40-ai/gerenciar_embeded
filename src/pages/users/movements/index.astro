---
import AppLayout from "../../../layouts/AppLayout.astro";
import UserSidebar from "../../../modules/users/components/UserSidebar.astro";
import MovementsList from "../../../modules/users/components/MovementsList";
---

<AppLayout title="Gerenciar - Movimentações de Colaboradores">
    <UserSidebar slot="sidebar" currentPath="/users/movements" />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Movimentações</h1>
            <p class="mt-1 text-sm text-gray-500">
                Histórico de alterações de cargos, setores e departamentos.
            </p>
        </div>

        <MovementsList client:load />
    </div>
</AppLayout>
