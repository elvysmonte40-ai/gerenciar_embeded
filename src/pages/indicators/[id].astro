---
import IndicatorsLayout from "../../modules/indicators/layouts/IndicatorsLayout.astro";
import { IndicatorDetails } from "../../modules/indicators/pages/IndicatorDetails";
import { supabase } from "../../lib/supabase";

const { id } = Astro.params;

// Optional: Server-side check if indicator exists or pre-fetch data (for SEO/Speed),
// but sticking to client-side fetching as implemented in React component for now for simplicity and interactivity.
// We might want to protect this route though.

const {
    data: { session },
} = await supabase.auth.getSession();

if (!session) {
    return Astro.redirect("/login");
}
---

<IndicatorsLayout title="Detalhes do Indicador">
    <IndicatorDetails indicatorId={id as string} client:only="react" />
</IndicatorsLayout>
