---
import AppLayout from "../../layouts/AppLayout.astro";
import UserSidebar from "../../modules/users/components/UserSidebar.astro";
import Organogram from "../../modules/users/components/Organogram";
---

<AppLayout title="Organograma - Gerenciar" fullWidth={true}>
    <UserSidebar slot="sidebar" currentPath={Astro.url.pathname} />

    <div class="h-full flex flex-col p-6">
        <div class="flex-1 flex flex-col overflow-hidden relative">
            <Organogram client:only="react" />
        </div>
    </div>
</AppLayout>
