---
import AppLayout from "../../../layouts/AppLayout.astro";
import AdminSidebar from "../../../components/AdminSidebar.astro";
import { AuditLogsViewer } from "../../../modules/admin/components/AuditLogsViewer";
---

<AppLayout title="Logs de Auditoria - Admin">
    <AdminSidebar slot="sidebar" />

    <div class="max-w-6xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-bold text-gray-900">
                Auditoria do Sistema
            </h1>
        </div>

        <AuditLogsViewer client:load />
    </div>
</AppLayout>
